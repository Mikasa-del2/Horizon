{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-chat",
    "base_url": "https://api.deepseek.com",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 0,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1
  },
  "email": {
    "enabled": true,
    "smtp_server": "smtp.office365.com",
    "smtp_port": 587,
    "imap_server": "imap.office365.com",
    "imap_port": 993,
    "email_address": "${EMAIL_ADDRESS}",
    "password_env": "OUTLOOK_PASSWORD",
    "sender_name": "Horizon Daily - 个人新闻雷达",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "sources": {
    "rss": [
      {
        "name": "HLTV.org - CS2 News",
        "url": "https://www.hltv.org/rss/news",
        "enabled": true,
        "category": "cs2-esports"
      },
      {
        "name": "HLTV.org - Results",
        "url": "https://www.hltv.org/rss/results",
        "enabled": true,
        "category": "cs2-esports"
      },
      {
        "name": "Liquipedia CS2 News",
        "url": "https://liquipedia.net/counterstrike/Portal:News/rss",
        "enabled": true,
        "category": "cs2-esports"
      },
      {
        "name": "Nature - Latest Research",
        "url": "https://www.nature.com/nature/research/rss",
        "enabled": true,
        "category": "science-breakthrough"
      },
      {
        "name": "Science Magazine - News",
        "url": "https://www.sciencemag.org/rss/current.xml",
        "enabled": true,
        "category": "science-breakthrough"
      },
      {
        "name": "DeepSeek Blog",
        "url": "https://www.deepseek.com/blog",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "MIT Technology Review - AI",
        "url": "https://www.technologyreview.com/feed/?tag=artificial-intelligence",
        "enabled": true,
        "category": "ai-tech"
      },
      {
        "name": "IEEE Power and Energy Magazine",
        "url": "https://ieeexplore.ieee.org/cgi-bin/feeds.pl?publication=IEEE+Power+and+Energy+Magazine",
        "enabled": true,
        "category": "electrical-engineering"
      },
      {
        "name": "IEEE Transactions on Power Systems",
        "url": "https://ieeexplore.ieee.org/cgi-bin/feeds.pl?publication=IEEE+Transactions+on+Power+Systems",
        "enabled": true,
        "category": "electrical-engineering"
      },
      {
        "name": "Nature Energy",
        "url": "https://www.nature.com/natenergy/research/rss",
        "enabled": true,
        "category": "electrical-engineering"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "worldnews",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 20,
          "min_score": 200,
          "category": "international-affairs"
        },
        {
          "subreddit": "geopolitics",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 100,
          "category": "international-affairs"
        },
        {
          "subreddit": "China",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 50,
          "category": "china-affairs"
        },
        {
          "subreddit": "taiwan",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 50,
          "category": "taiwan-affairs"
        },
        {
          "subreddit": "GlobalOffensive",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 20,
          "min_score": 100,
          "category": "cs2-esports"
        },
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 100,
          "category": "ai-research"
        },
        {
          "subreddit": "OpenAI",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 50,
          "category": "ai-news"
        }
      ],
      "fetch_comments": 5
    },
    "twitter": {
      "enabled": true,
      "users": [
        "HLTV",
        "Liquipedia",
        "OpenAI",
        "ylecun",
        "karpathy",
        "elonmusk",
        "SpaceX"
      ],
      "fetch_limit": 20,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 15,
      "reply_min_likes": 10
    },
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 25,
      "min_score": 200,
      "category": "tech-news"
    }
  },
  "filtering": {
    "ai_score_threshold": 5.5,
    "time_window_hours": 24,
    "max_items": 45,
    "category_groups": {
      "cs2-esports": {
        "limit": 8,
        "categories": ["cs2-esports"]
      },
      "international": {
        "limit": 10,
        "categories": ["international-affairs"]
      },
      "china-taiwan": {
        "limit": 8,
        "categories": ["china-affairs", "taiwan-affairs"]
      },
      "science": {
        "limit": 7,
        "categories": ["science-breakthrough"]
      },
      "ai": {
        "limit": 8,
        "categories": ["ai-news", "ai-research", "ai-tech"]
      },
      "engineering": {
        "limit": 4,
        "categories": ["electrical-engineering"]
      }
    },
    "default_group": "other",
    "default_group_limit": 3
  },
  "outputs": {
    "email": {
      "enabled": true
    },
    "github_pages": {
      "enabled": true
    }
  }
}
